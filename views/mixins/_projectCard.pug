include _projectLinks

mixin projectCard(project, lazyLoad=false, showTechs=false)
  .project-card
    a.project-card__img-link(href=`/projects/${project.slug}/`)

      - const im = project.coverImage
      if lazyLoad
        img.project-card__img.lazy-img(srcset=`${imageBaseUrl}/${sizeImageUrl(im, '-lazy')} 1x, ${imageBaseUrl}/${sizeImageUrl(im, '-lazy')} 2x`
        data-srcset=`${imageBaseUrl}/${sizeImageUrl(im, '-small')} 1x, ${imageBaseUrl}/${im} 2x`
        src=`${imageBaseUrl}/${sizeImageUrl(im, '-lazy')}`
        alt=project.coverImageAltText)
      else
        img.project-card__img(srcset=`${imageBaseUrl}/${sizeImageUrl(im, '-small')} 1x, ${imageBaseUrl}/${im} 2x`
        src=`${imageBaseUrl}/${project.coverImage}`
        alt=project.coverImageAltText)

    a.project-card__title(href=`/projects/${project.slug}/`)
      svg.project-card__icon: use(xlink:href=`/img/sprite.svg#icon-${project.categories[0]}`, alt=`${project.categories[0]}`)
      span.project-card__name= project.name
    a(href=`/projects/${project.slug}/`).project-card__summary= project.summary
    if showTechs && project.techsUsed && project.techsUsed.length
      .project-card__techs
        each tech in project.techsUsed
          svg.project-card__tech-icon
            use(xlink:href=`/img/sprite.svg#icon-${tech}`, alt=`${tech} icon`)
    .project-card__links
      +projectLinks(project)
