if projects
  include ../../mixins/_projectCard

  section.feat-projects#feat-projects
    .section-container.pt-lg.pb-lg
      .title-container.mb-md
        span.section-title featured projects
      .feat-projects__content
        if projects[0]
          +projectCard(projects[0], lazyLoad=true)
        if projects[1]
          +projectCard(projects[1], lazyLoad=true)
        if projects[2]
          +projectCard(projects[2], lazyLoad=true)
      .feat-projects__btn
        a.btn.btn--blue(href='/projects') See All Projects &rarr;
